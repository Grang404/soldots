#!/bin/bash

set -o pipefail

DOTFILES_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly DOTFILES_ROOT
readonly DOTS_DIR="$DOTFILES_ROOT/dots"
readonly LOG_DIR="$DOTFILES_ROOT/logs"
readonly CONFIG_DIR="$HOME/.config"

readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly NC='\033[0m'

LOG_FILE=""

log() {
	local msg
	msg="[$(date '+%Y-%m-%d %H:%M:%S')] $*"
	[[ -n "$LOG_FILE" ]] && echo "$msg" >>"$LOG_FILE"
}

error() {
	echo -e "${RED}ERROR: $*${NC}" >&2
	log "ERROR: $*"
	exit 1
}

warn() {
	echo -e "${YELLOW}WARNING: $*${NC}" >&2
	log "WARNING: $*"
}

success() {
	echo -e "${GREEN}$*${NC}"
	log "$*"
}

check_dependencies() {
	local deps=("rsync")
	for dep in "${deps[@]}"; do
		command -v "$dep" >/dev/null 2>&1 || error "$dep is not installed."
	done
}

setup_log() {
	mkdir -p "$LOG_DIR" || error "Failed to create log directory"
	LOG_FILE="$LOG_DIR/dots-$(date +%Y%m%d-%H%M%S).log"
}

# sync: system -> dots dir
sync_item() {
	local source="$1"
	local target="$2"
	local name
	name="$(basename "$source")"

	if [[ ! -e "$source" ]]; then
		warn "Skipping $name - not found: $source"
		return 1
	fi

	log "Syncing $name"
	mkdir -p "$(dirname "$target")"

	local rsync_output
	local rsync_opts=(-a -v -h --progress --delete)

	[[ "$name" == "zsh" ]] && rsync_opts+=(--exclude='plugins/' --exclude='themes/')

	if [[ -d "$source" ]]; then
		rsync_output=$(rsync "${rsync_opts[@]}" "$source/" "$target/" 2>&1) && {
			log "$rsync_output"
			success "Synced $name"
			return 0
		}
	else
		rsync_output=$(rsync "${rsync_opts[@]}" "$source" "$target" 2>&1) && {
			log "$rsync_output"
			success "Synced $name"
			return 0
		}
	fi

	log "$rsync_output"
	warn "Failed to sync $name"
	return 1
}

cmd_pull() {
	local sync_count=0 fail_count=0

	check_dependencies
	setup_log
	log "=== Sync Started ==="
	mkdir -p "$DOTS_DIR" || error "Failed to create dots directory"

	local config_dirs=(
		"hypr"
		"waybar"
		"kitty"
		"rofi"
		"fastfetch"
		"gtk-2.0"
		"gtk-3.0"
		"gtk-4.0"
	)

	for dir in "${config_dirs[@]}"; do
		if sync_item "$HOME/.config/$dir" "$DOTS_DIR/$dir"; then
			((sync_count++))
		else
			((fail_count++))
		fi
	done

	for f in .zshrc .zprofile .zshenv; do
		name="${f#.}"
		if sync_item "$HOME/$f" "$DOTS_DIR/$name"; then
			((sync_count++))
		else
			((fail_count++))
		fi
	done

	if sync_item "$HOME/Pictures/wallpapers" "$DOTS_DIR/wallpapers"; then
		((sync_count++))
	else
		((fail_count++))
	fi

	log "=== Sync Complete: $sync_count ok, $fail_count failed ==="
	[[ $fail_count -gt 0 ]] && warn "Failed/Skipped: $fail_count items"
	success "Sync complete. Log: $LOG_FILE"
}

# move: dots dir -> system
cmd_push() {
	check_dependencies
	setup_log
	log "=== Move Started ==="

	[[ -d "$DOTS_DIR" ]] || error "dots directory not found: $DOTS_DIR"

	local shared_dirs=("fastfetch" "gtk-2.0" "gtk-3.0" "gtk-4.0" "rofi" "waybar" "kitty")

	for dir in "${shared_dirs[@]}"; do
		if [[ -d "$DOTS_DIR/$dir" ]]; then
			log "Moving $dir"
			if rsync -a --delete "$DOTS_DIR/$dir/" "$CONFIG_DIR/$dir/"; then
				success "Moved $dir"
			else
				warn "Failed to move $dir"
			fi
		fi
	done

	if [[ -d "$CONFIG_DIR/zsh/plugins" && -d "$CONFIG_DIR/zsh/themes" ]]; then
		if [[ -d "$DOTS_DIR/zsh" ]]; then
			log "Moving zsh"
			if rsync -a --delete \
				--exclude='plugins/' \
				--exclude='themes/' \
				"$DOTS_DIR/zsh/" "$CONFIG_DIR/zsh/"; then
				success "Moved zsh"
			else
				warn "Failed to move zsh"
			fi
		fi
	else
		warn "ZSH plugins/themes not found, skipping zsh (run install.sh first)"
	fi

	if [[ -d "$DOTS_DIR/hypr" ]]; then
		log "Moving hypr"
		rsync -a --delete "$DOTS_DIR/hypr/" "$CONFIG_DIR/hypr/"
		success "Moved hypr"
	fi

	for dotfile in "zshrc" "zprofile" "zshenv"; do
		if [[ -f "$DOTS_DIR/$dotfile" ]]; then
			if cp "$DOTS_DIR/$dotfile" "$HOME/.$dotfile"; then
				success "Moved $dotfile"
			else
				warn "Failed to move $dotfile"
			fi
		fi
	done

	if [[ -d "$DOTS_DIR/wallpapers" ]]; then
		log "Moving wallpapers"
		if rsync -a --delete "$DOTS_DIR/wallpapers/" "$HOME/Pictures/wallpapers/"; then
			success "Moved wallpapers"
		else
			warn "Failed to move wallpapers"
		fi
	fi

	log "=== Move Complete ==="
	success "Move complete. Log: $LOG_FILE"
}

usage() {
	echo "Usage: $(basename "$0") <command>"
	echo ""
	echo "Commands:"
	echo "  --pull    Sync dotfiles from system into dots dir"
	echo "  --push    Move dotfiles from dots dir to system"
}

case "${1:-}" in
--pull) cmd_pull ;;
--push) cmd_push ;;
*)
	usage
	exit 1
	;;
esac
